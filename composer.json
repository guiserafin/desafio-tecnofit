{
    "name": "tecnofit/movement-ranking",
    "description": "Movement ranking REST API challenge implementation in pure PHP.",
    "type": "project",
    "license": "proprietary",
    "require": {
        "php": "^8.3",
        "ext-mbstring": "*",
        "ext-pdo": "*",
        "ext-pdo_mysql": "*"
    },
    "require-dev": {
        "friendsofphp/php-cs-fixer": "^3.66",
        "phpunit/phpunit": "^11.0"
    },
    "autoload": {
        "psr-4": {
            "Tecnofit\\MovementRanking\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Tests\\": "tests/"
        }
    },
    "scripts": {
        "test": "phpunit --testdox",
        "test:unit": "phpunit --testsuite Unit",
        "test:integration": "phpunit --testsuite Integration",
        "lint": "php-cs-fixer fix --dry-run --diff",
        "lint:fix": "php-cs-fixer fix"
    },
    "config": {
        "sort-packages": true
    }
}
